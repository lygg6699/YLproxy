# YLproxy .gitignore
# 生成日期：2026-07-21

# ====== 构建产物 ======
bin/
obj/
**/bin/
**/obj/
src/*/bin/
src/*/obj/
tests/bin/
tests/obj/
build_stdout.txt
build.binlog
test_3proxy.cfg
*.binlog

# ====== 发布产物 ======
publish/
*/bin/*/publish/

# ====== WPF 编译缓存 ======
**/*_wpftmp/

# ====== NuGet ======
packages/
*.nupkg

# ====== 日志文件 ======
logs/
runtime/3proxy/logs/
*.log

# ====== 数据和本地配置 ======
data/config.json
data/config.json.bak
AppSettings.local.json

# ====== 测试产物 ======
TestResults/
coverage/
*.trx
*.coverage
coverage.json
*.opencover.xml

# ====== 运行时文件 ======
runtime/3proxy/bin64/
runtime/3proxy/cfg/
runtime/3proxy/logs/

# ====== AI 代理临时文件 ======
.blackbox/tmp/
.blackboxcli/
.clinerules/

# ====== 临时文件和缓存 ======
*.cache
*.user
*.suo
*.pidb
*.sln.docstates
*.vs
*.tmp
*.bak
*.swp
*.swo

# ====== IDE 配置 ======
.vscode/
.idea/
.vs/

# ====== OS 文件 ======
Thumbs.db
.DS_Store
Desktop.ini

# ====== 执行方案文档（不提交仓库，仅本地执行参考） ======
CI修复执行方案_步骤*.md
完整的工程债与技术债清偿执行方案_*.md
docs/issues/*执行方案.md
