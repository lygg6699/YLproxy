{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WPF: YLproxy.GUI (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build (Debug)",
      "program": "${workspaceFolder}/src/YLproxy.GUI/bin/Debug/net10.0-windows/YLproxy.GUI.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": ".NET Test: YLproxy.Tests (Debug)",
      "type": "dotnet-test",
      "request": "launch",
      "preLaunchTask": "dotnet: build (Debug)",
      "project": "${workspaceFolder}/tests/YLproxy.Tests.csproj",
      "arguments": "--configuration Debug",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}

