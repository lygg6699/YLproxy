<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Constants -->
    <Color x:Key="BgDarkColor">#1E1E1E</Color>
    <Color x:Key="BgPanelColor">#252526</Color>
    <Color x:Key="BgInputColor">#3E3E3E</Color>
    <Color x:Key="BorderColor">#3E3E3E</Color>
    <Color x:Key="BorderInputColor">#555555</Color>
    <Color x:Key="FgPrimaryColor">#CCCCCC</Color>
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="SelectedColor">#094771</Color>
    <Color x:Key="ErrorColor">#B00020</Color>
    <Color x:Key="SuccessColor">#2E7D32</Color>
    <Color x:Key="WarnColor">#F9A825</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDarkColor}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInputColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderInputBrush" Color="{StaticResource BorderInputColor}"/>
    <SolidColorBrush x:Key="FgPrimaryBrush" Color="{StaticResource FgPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1A8AE8"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}"/>

    <SolidColorBrush x:Key="FgDimBrush" Color="#888888"/>
    <SolidColorBrush x:Key="FgMutedBrush" Color="#666666"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="DisabledButtonBackgroundBrush" Color="#555555"/>
    <SolidColorBrush x:Key="DisabledButtonForegroundBrush" Color="#888888"/>

    <!-- Window -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgDarkBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

    <!-- GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource DisabledButtonBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource DisabledButtonBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource DisabledButtonForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderInputBrush}"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderInputBrush}"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- ListBox -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- ListView -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource HeaderBackgroundBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SelectedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="IsSelected" Value="False"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="8,4"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SelectedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderInputBrush}"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
    </Style>

</ResourceDictionary>
