<UserControl x:Class="YLproxy.GUI.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:YLproxy.GUI"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Host Info + Operations -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="本机信息" Grid.Column="0">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <TextBlock Text="电脑名" Foreground="#888"/>
                    <TextBlock Text="{Binding ComputerName}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <TextBlock Text="IP 地址" Foreground="#888"/>
                    <TextBlock Text="{Binding IpAddress}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <TextBlock Text="网络状态" Foreground="#888"/>
                    <TextBlock Text="{Binding NetworkStatus}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <TextBlock Text="时间" Foreground="#888"/>
                    <TextBlock Text="{Binding Now, StringFormat={}{0:HH:mm:ss}}" FontWeight="SemiBold"/>
                </StackPanel>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch"/>

            <GroupBox Header="操作区" Grid.Column="2">
                <DockPanel LastChildFill="True" Margin="10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,4">
                        <Button Content="添加" Width="72" Margin="0,0,6,0" Command="{Binding AddCommand}"/>
                        <Button Content="删除" Width="72" Margin="0,0,6,0" Command="{Binding RemoveCommand}"/>
                        <Button Content="测试" Width="72" Margin="0,0,6,0" ToolTip="测试选中的代理"
                                Command="{Binding TestCommand}"
                                IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="启动" Width="72" Margin="0,0,6,0"
                                Command="{Binding StartCommand}"
                                IsEnabled="{Binding IsStarting, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="停止" Width="72" Margin="0,0,6,0"
                                Command="{Binding StopCommand}"
                                IsEnabled="{Binding IsStopping, Converter={StaticResource InverseBoolConverter}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,4,0,4">
                        <Button Content="批量启动" Width="72" Margin="0,0,6,0" ToolTip="启动所有选中的代理"
                                Command="{Binding BatchStartCommand}"
                                IsEnabled="{Binding IsStarting, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="批量停止" Width="72" Margin="0,0,6,0" ToolTip="停止所有选中的代理"
                                Command="{Binding BatchStopCommand}"
                                IsEnabled="{Binding IsStopping, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="导出" Width="56" Margin="0,0,6,0" ToolTip="导出代理列表到JSON文件"
                                Command="{Binding ExportCommand}"/>
                        <Button Content="导入" Width="56" Margin="0,0,6,0" ToolTip="从JSON文件导入代理列表"
                                Command="{Binding ImportCommand}"/>
                    </StackPanel>

                    <TextBlock Text="(Phase 8) 已接入添加/删除/测试/启动/停止/批量/搜索/导入导出功能。" Foreground="#888"
                               FontSize="11" VerticalAlignment="Bottom"/>
                </DockPanel>
            </GroupBox>
        </Grid>

        <!-- Row 1: Dashboard Stats Bar -->
        <Border Grid.Row="1" Margin="10,0,10,6" Padding="8,6" Background="#2D2D30" CornerRadius="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="总计：" Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount}" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource FgPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="运行中：" Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RunningCount}" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Width="10" Height="10" Fill="#888888" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="已停止：" Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StoppedCount}" FontWeight="Bold" FontSize="16"
                               Foreground="#888888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource ErrorBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="失败：" Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FailedCount}" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource ErrorBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Proxy List with Search -->
        <GroupBox Grid.Row="2" Margin="10,0" Header="代理列表">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E1E" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                 Background="#3E3E3E" Foreground="#CCCCCC"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"/>
                        <TextBlock Grid.Column="0" Text="🔍 搜索代理名称、IP、用户名..."
                                   Foreground="#666" IsHitTestVisible="False"
                                   Padding="8,4" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1" Content="✕" Width="28" Height="24"
                                Background="Transparent" Foreground="#888" BorderThickness="0"
                                Padding="0" FontSize="14"
                                Command="{Binding ClearSearchCommand}"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredProxies}"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          SelectionChanged="DataGrid_SelectionChanged"
                          HeadersVisibility="Column" IsReadOnly="True"
                          AlternationCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="代理名称" Binding="{Binding Name}" Width="130"/>
                        <DataGridTextColumn Header="上游IP" Binding="{Binding RemoteHost}" Width="*"/>
                        <DataGridTextColumn Header="上游端口" Binding="{Binding RemotePort}" Width="80"/>
                        <DataGridTextColumn Header="账号" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="本地IP" Binding="{Binding LocalHost}" Width="120"/>
                        <DataGridTextColumn Header="本地端口" Binding="{Binding LocalPort}" Width="80"/>
                        <DataGridTemplateColumn Header="状态" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2"
                                            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11"
                                                   HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Row 3: Log Panel -->
        <GroupBox Grid.Row="3" Margin="10" Header="运行日志">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="级别：" VerticalAlignment="Center" FontSize="11" Foreground="#888" Margin="0,0,6,0"/>
                    <ComboBox Width="90" Height="22"
                              ItemsSource="{Binding LogLevels}"
                              SelectedItem="{Binding SelectedLogLevel}"
                              Background="#3E3E3E" Foreground="#CCCCCC"
                              FontSize="11"/>
                </StackPanel>

                <ListView Grid.Row="1" x:Name="LogListView"
                          ItemsSource="{Binding FilteredLogs}"
                          Background="#1E1E1E" Foreground="#CCCCCC"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.ScrollUnit="Pixel">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Text, Converter={StaticResource LogLevelToColorConverter}}"
                                       FontFamily="Consolas" FontSize="11"
                                       Padding="2,0" TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2" Content="清空日志" Width="80" Height="24"
                        Command="{Binding ClearLogCommand}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
