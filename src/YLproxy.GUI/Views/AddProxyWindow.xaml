<Window x:Class="YLproxy.GUI.Views.AddProxyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YLproxy.GUI.Views"
        mc:Ignorable="d"
        Title="添加代理"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="16" Text="请输入代理信息"/>

        <!-- Name -->
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="代理名称" Foreground="#555"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- RemoteHost -->
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="服务器IP" Foreground="#555"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                 Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- RemotePort -->
        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="服务器端口" Foreground="#555"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                 Text="{Binding RemotePortText, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Username -->
        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="用户名" Foreground="#555"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,8,0,0"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="密码" Foreground="#555"/>
<PasswordBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" PasswordChanged="OnPasswordChanged"/>

        <!-- AutoPort -->
        <CheckBox Grid.Row="6" Grid.ColumnSpan="2" Margin="0,10,0,0"
                  Content="自动分配本地端口"
                  IsChecked="{Binding IsAutoPort, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- LocalPort -->
        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,10,0" VerticalAlignment="Center" Text="本地端口" Foreground="#555"/>
<TextBox Grid.Row="7" Grid.Column="1" Margin="0,8,0,0"
                 Text="{Binding LocalPortText, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Validation error -->
        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="#B00020" TextWrapping="Wrap" Text="{Binding ValidationMessage}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Width="90" Margin="0,0,10,0" IsCancel="True" Click="OnCancelClicked"/>
            <Button Content="确定" Width="90" Command="{Binding ConfirmCommand}"/>
        </StackPanel>
    </Grid>
</Window>

