{
  "Logging": {
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "MinLevel": "Info"
  },
  "Proxy": {
    "DataDirectory": "data",
    "ConfigFileName": "config.json",
    "PortRangeStart": 9001,
    "PortRangeEnd": 9099,
    "CheckIntervalSeconds": 5
  },
  "ThreeProxy": {
    "RuntimeDirectory": "runtime/3proxy",
    "RequiredDlls": [
      "FilePlugin.dll",
      "StringsPlugin.dll"
    ]
  },
  "Api": {
    "Port": 9100,
    "AccessToken": "CHANGE_ME_ON_FIRST_RUN"
  },
  "Startup": {
    "AutoStart": false
  }
}

