# YLproxy Git Attributes
# 统一行尾符规范

# 默认自动检测文本/二进制，文本文件使用 LF
* text=auto eol=lf

# 特定源代码文件强制 LF
*.cs        text eol=lf
*.cpp       text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.htm       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.less      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.config    text eol=lf

# Windows 脚本保留 CRLF
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Unix 脚本保留 LF
*.sh        text eol=lf

# 二进制文件
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.rar       binary
*.7z        binary
*.exe       binary
*.dll       binary
*.pdb       binary
*.lib       binary
*.so        binary
*.dylib     binary
